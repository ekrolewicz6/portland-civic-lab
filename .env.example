# === Portland Civic Lab Dashboard — Environment Variables ===
# Copy this file to .env.local and fill in your values.

# --- Database ---
DATABASE_URL=postgresql://postgres:password@localhost:5432/portland_dashboard
DATABASE_URL_UNPOOLED=postgresql://postgres:password@localhost:5432/portland_dashboard

# --- Next.js ---
NEXT_PUBLIC_APP_URL=http://localhost:3000

# --- Mapbox ---
NEXT_PUBLIC_MAPBOX_TOKEN=

# --- External APIs ---
TRIMET_APP_ID=
CENSUS_API_KEY=
BLS_API_KEY=

# --- Placer.ai (if direct subscription) ---
PLACER_API_KEY=

# --- Email Digest (Portland Pulse) ---
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
PULSE_FROM_EMAIL=
PULSE_REPLY_TO=

# --- Public Contact Form ---
# CONTACT_TO_EMAIL is the private recipient. Do not render it in public UI.
CONTACT_TO_EMAIL=
CONTACT_FROM_EMAIL=

# If mail is not configured, Vercel can persist contact submissions to DATABASE_URL.
# Local development uses runtime-data/contact-submissions/ unless this is enabled.
CONTACT_DATABASE_FALLBACK=false

# Either configure Resend:
RESEND_API_KEY=

# Or configure SMTP using SMTP_HOST/SMTP_PORT/SMTP_USER/SMTP_PASS above.
SMTP_SECURE=false

# --- AI Concierge (Claude) ---
ANTHROPIC_API_KEY=

# --- Membership auth (WorkOS AuthKit) ---
# Create an application at https://dashboard.workos.com and enable AuthKit.
# Sign-in/signup stay in "coming soon" mode until all three are set.
WORKOS_API_KEY=
WORKOS_CLIENT_ID=
# 32+ chars; generate with: openssl rand -base64 24
WORKOS_COOKIE_PASSWORD=
# Optional in local dev; set to .portlandciviclab.org in production so Civic Lab
# auth sessions work across www.portlandciviclab.org and beds.portlandciviclab.org.
WORKOS_COOKIE_DOMAIN=
# Must match the redirect URI configured in the WorkOS dashboard
NEXT_PUBLIC_WORKOS_REDIRECT_URI=http://localhost:3000/auth/callback

# --- Cron & security ---
# Required in production: cron routes reject all requests without it
CRON_SECRET=

# Comma-separated emails granted the admin role on sign-in
ADMIN_EMAILS=
